<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title><%= title %></title>
<style>
    :root{
        --bg:#eef2f7;
        --card:#ffffff;
        --border:#e5e7eb;
        --text:#111827;
        --muted:#6b7280;
        --green:#22c55e;
        --yellow:#f59e0b;
        --red:#ef4444;
        --gray:#cbd5e1;
    }

    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
    }

    body{
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background:var(--bg);
        color:var(--text);
        padding:18px;
    }

    /* HEADER */

    .topbar{
        display:flex;
        justify-content:space-between;
        align-items:center;
        margin-bottom:18px;
    }

    h1{
        font-size:28px;
        font-weight:800;
        letter-spacing:-1px;
    }

    .subtitle{
        margin-top:4px;
        color:var(--muted);
        font-size:14px;
    }

    .live{
        display:flex;
        align-items:center;
        gap:10px;
        background:#fff;
        border:1px solid var(--border);
        border-radius:14px;
        padding:10px 14px;
        font-size:13px;
        color:var(--muted);
    }

    .live-dot{
        width:10px;
        height:10px;
        border-radius:50%;
        background:var(--green);
        animation:pulse 1.8s infinite;
    }

    @keyframes pulse{
        0%{
            box-shadow:0 0 0 0 rgba(34,197,94,.6);
        }

        70%{
            box-shadow:0 0 0 10px rgba(34,197,94,0);
        }

        100%{
            box-shadow:0 0 0 0 rgba(34,197,94,0);
        }
    }

    /* MASONRY GRID */
    .grid {
        column-count:4;
        column-gap:18px;
    }

    @media(max-width:1500px) {
        .grid{
            column-count:3;
        }
    }

    @media(max-width:1100px) {
        .grid {
            column-count:2;
        }
    }

    @media(max-width:700px) {
        .grid {
            column-count:1;
        }

        .topbar {
            flex-direction:column;
            align-items:flex-start;
            gap:12px;
        }
    }

    /* CARD */
    .queue {
        break-inside:avoid;
        margin-bottom:18px;
        background:var(--card);
        border:1px solid var(--border);
        border-radius:22px;
        overflow:hidden;
        box-shadow:  0 4px 20px rgba(15,23,42,.06);
        transition:
        transform .15s ease,
        box-shadow .15s ease;
    }

    .queue:hover{
        transform:translateY(-2px);
        box-shadow: 0 10px 30px rgba(15,23,42,.12);
    }

    .queue-header{
        display:flex;
        justify-content:space-between;
        align-items:center;
        padding:16px 18px;
        border-bottom:1px solid var(--border);
        background: linear-gradient(to bottom, #fafafa, #fff);
    }

    .queue-title{
        font-size:17px;
        font-weight:700;
    }

    .queue-count{
        background:#eff6ff;
        color:#2563eb;
        padding:5px 10px;
        border-radius:999px;
        font-size:12px;
        font-weight:700;
    }

    /* MEMBERS */

    .member{
        display:flex;
        justify-content:space-between;
        align-items:center;
        padding:14px 18px;
        transition: background .15s ease, opacity .15s ease;
    }

    .member:hover{
        background:#f8fafc;
    }

    .member:not(:last-child){
        border-bottom:1px solid #f1f5f9;
    }

    .member.offline{
        opacity:.42;
    }

    .left{
        display:flex;
        flex-direction:column;
    }

    .name{
        font-size:15px;
        font-weight:700;
        margin-bottom:2px;
    }

    .meta{
        font-size:12px;
        color:var(--muted);
    }

    /* STATUS */
    .status{
        display:flex;
        align-items:center;
        gap:8px;
        min-width:90px;
        justify-content:flex-end;
    }

    .status-circle{
        width:11px;
        height:11px;
        border-radius:999px;
        position:relative;
    }

    .status-circle::after{
        content:"";
        position:absolute;
        inset:-4px;
        border-radius:999px;
        opacity:.18;
    }

    .green{
        background:var(--green);
    }

    .green::after{
        background:var(--green);
    }

    .yellow{
        background:var(--yellow);
    }

    .yellow::after{
        background:var(--yellow);
    }

    .red{
        background:var(--red);
    }

    .red::after{
        background:var(--red);
    }

    .gray{
        background:var(--gray);
    }

    .gray::after{
        background:var(--gray);
    }

    .status-text{
        font-size:12px;
        color:var(--muted);
        font-weight:600;
        text-transform:capitalize;
    }

    /* EMPTY */
    .empty{
        padding:18px;
        color:var(--muted);
        font-size:13px;
    }
</style>
</head>
<body>
<div class="topbar">
    <div>
        <h1><%= title %></h1>
        <div class="subtitle">
            Live Presence Dashboard
        </div>
    </div>
    <div class="live">
        <div class="live-dot"></div>
        1x/Min REFRESH
    </div>
</div>

<div class="grid">
    <% queues.forEach(queue => { %>
        <div class="queue">
            <div class="queue-header">
                <div class="queue-title">
                    <%= queue.name %>
                </div>

                <div class="queue-count">
                    <%= queue.members.length %>
                </div>
            </div>

            <% if(queue.members.length === 0){ %>
                <div class="empty">
                    Keine Mitglieder vorhanden
                </div>
            <% } %>

            <% queue.members.forEach(member => { %>
                <div class="member" data-ext="<%= member.extension %>">
                    <div class="left">
                    <div class="name">
                        <%= member.name %>
                    </div>
                    <div class="meta">
                        Ext. <%= member.extension %>
                    </div>
                    </div>
                    <div class="status">
                    <div class="status-circle gray"></div>
                    <div class="status-text">
                        loading
                    </div>
                    </div>
                </div>
            <% }); %>
        </div>
    <% }); %>
</div>

<script>
    async function loadPresence() {
        try {
            const members = document.querySelectorAll(".member");
            const extensions = [...new Set([...members].map(m => m.dataset.ext))];
            const res = await fetch("/presence?ext=" + extensions.join(","));
            const data = await res.json();
            const statusMap = new Map();

            data.forEach(p => {
                if (p.online === false) {
                    statusMap.set(p.extension,"offline");
                    return;
                }

                if (p.online === true &&(!p.show || p.show === "")) {
                    statusMap.set(p.extension, "green");
                    return;
                }

                if (p.show === "away") {
                    statusMap.set(p.extension, "yellow");
                    return;
                }

                if (p.show === "dnd") {
                    statusMap.set(p.extension,"red");
                    return;
                }

                statusMap.set(p.extension, "green");
            });

            members.forEach(el => {
                const ext = el.dataset.ext;
                const circle = el.querySelector(".status-circle");
                const text = el.querySelector(".status-text");
                const status = statusMap.get(ext);

                if (!status) {
                    circle.style.display = "none";
                    text.textContent = "";
                    return;
                }

                circle.style.display = "inline-block";

                el.classList.remove("offline");

                if (status === "offline") {
                    el.classList.add("offline");
                    circle.className = "status-circle gray";
                    text.textContent = "offline";
                    return;
                }

                if (status === "green") {
                    circle.className = "status-circle green";
                    text.textContent = "online";
                    return;
                }

                if (status === "yellow") {
                    circle.className = "status-circle yellow";
                    text.textContent ="away";
                    return;
                }

                if (status === "red") {
                    circle.className = "status-circle red";
                    text.textContent = "dnd";
                    return;
                }
            });
        } catch(e) {
            console.error(
            "Presence error:",
            e
            );
        } finally {
            setTimeout(loadPresence, 60000);
        }
    }

    // INITIAL
    loadPresence();
</script>
</body>
</html>